# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin emails (comma-separated, for Regulations admin access)
VITE_ADMIN_EMAILS=your-email@example.com

# Server-side only (Vercel Environment Variables, NOT prefixed with VITE_)
# ANTHROPIC_API_KEY=sk-ant-...
# ADMIN_EMAILS=your-email@example.com
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (optional, for admin operations)
